      </select>
      </div>

      <div>
        <label class="block text-sm mb-1 text-zinc-300">Valor (R$)</label>
        <input id="preco_display" type="text" inputmode="numeric" value="<?= htmlspecialchars($precoInicial) ?>"
               class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2" placeholder="0,00">
      </div>
    </div>

    <div>
      <label class="block text-sm mb-1 text-zinc-300">Nome</label>
      <input name="nome" maxlength="120" required
             value="<?= htmlspecialchars((string)($produto['nome'] ?? '')) ?>"
             class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2"
             placeholder="Nome do produto">
    </div>

    <div>
      <label class="block text-sm mb-1 text-zinc-300">Descrição</label>
      <textarea name="descricao" rows="4" class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2"
                placeholder="Descrição"><?= htmlspecialchars((string)($produto['descricao'] ?? '')) ?></textarea>
    </div>

    <div>
      <label class="block text-sm mb-1 text-zinc-300">Imagem</label>
      <input id="imagemInput" type="file" name="imagem" accept=".jpg,.jpeg,.png,.webp"
             class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2">
      <img id="imgPreview" src="<?= htmlspecialchars($imgAtual) ?>"
           class="mt-2 h-24 w-24 object-cover rounded border border-blackx3 <?= $imgAtual ? '' : 'hidden' ?>">
    </div>

    <div class="pt-2 flex items-center justify-end gap-3">
      <a href="/mercado_admin/public/vendedor/produtos.php" class="rounded-lg border border-blackx3 text-zinc-300 px-5 py-2.5 hover:border-greenx hover:text-white transition-all">
        Cancelar
      </a>
      <button id="produto-submit" type="submit" class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-greenx to-emerald-600 text-black font-semibold px-5 py-2.5 hover:from-greenx2 hover:to-emerald-700 shadow-lg shadow-greenx/20 transition-all">
        <i data-lucide="save" class="w-4 h-4" id="produto-submit-icon"></i>
        <span id="produto-submit-label">Salvar produto</span>
      </button>
    </div>
  </form>
  </div>
</div>

<script>
(function () {
  const form = document.getElementById('produto-form');
  const submitBtn = document.getElementById('produto-submit');
  const submitLabel = document.getElementById('produto-submit-label');
  const submitIcon = document.getElementById('produto-submit-icon');

  if (form && submitBtn && submitLabel && submitIcon) {
    form.addEventListener('submit', () => {
      if (submitBtn.disabled) return;
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      submitLabel.textContent = 'Salvando...';
      submitIcon.setAttribute('data-lucide', 'loader-2');
      submitIcon.classList.add('animate-spin');
      if (window.lucide && typeof window.lucide.createIcons === 'function') {
        window.lucide.createIcons();
      }
    });
  }

  const display = document.getElementById('preco_display');
  const hidden = document.getElementById('preco');

  function onlyDigits(v){ return (v || '').replace(/\D/g, ''); }
  function toBRL(digits){
    if (!digits) return '0,00';
    const n = Number(digits) / 100;
    return n.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  function brlToFloat(brl){
    const s = (brl || '').replace(/\./g, '').replace(',', '.').replace(/[^\d.]/g, '');
    return Number(s || 0).toFixed(2);
  }

  if (display && hidden) {
    display.value = toBRL(onlyDigits(display.value));
    hidden.value = brlToFloat(display.value);

    display.addEventListener('input', () => {
      display.value = toBRL(onlyDigits(display.value));
      hidden.value = brlToFloat(display.value);
    });
  }

  const input = document.getElementById('imagemInput');
  const preview = document.getElementById('imgPreview');
  if (input && preview) {
    input.addEventListener('change', () => {
      const file = input.files && input.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        preview.src = String(e.target?.result || '');
        preview.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    });
  }
})();
</script>

