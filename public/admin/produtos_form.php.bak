        <?php endif; ?>
        <input type="hidden" name="imagem_atual" value="<?= htmlspecialchars((string)($produto['imagem'] ?? '')) ?>">
        <input type="hidden" id="preco" name="preco" value="<?= htmlspecialchars(str_replace(',', '.', str_replace('.', '', $precoInicial))) ?>">

        <div>
            <label class="block text-sm mb-1 text-zinc-300">Vendedor</label>
            <select name="vendedor_id" required class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2">
                <option value="">Selecione o vendedor</option>
                <?php foreach ($vendedores as $v): ?>
                    <option value="<?= (int)$v['id'] ?>" <?= (int)($produto['vendedor_id'] ?? 0) === (int)$v['id'] ? 'selected' : '' ?>>
                        <?= htmlspecialchars($v['nome']) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div>
            <label class="block text-sm mb-1 text-zinc-300">Categoria</label>
            <select name="categoria_id" required class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2">
                <option value="">Selecione a categoria</option>
                <?php foreach ($categorias as $c): ?>
                    <option value="<?= (int)$c['id'] ?>" <?= (int)($produto['categoria_id'] ?? 0) === (int)$c['id'] ? 'selected' : '' ?>>
                        <?= htmlspecialchars($c['nome']) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div>
            <label class="block text-sm mb-1 text-zinc-300">Nome</label>
            <input name="nome" maxlength="120" required
                   value="<?= htmlspecialchars((string)($produto['nome'] ?? '')) ?>"
                   class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2"
                   placeholder="Nome do produto">
        </div>

        <div>
            <label class="block text-sm mb-1 text-zinc-300">Descrição</label>
            <textarea name="descricao" rows="4"
                      class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2"
                      placeholder="Descrição"><?= htmlspecialchars((string)($produto['descricao'] ?? '')) ?></textarea>
        </div>

        <div>
            <label class="block text-sm mb-1 text-zinc-300">Valor (R$)</label>
            <input id="preco_display" name="preco_display" type="text" inputmode="numeric"
                   value="<?= htmlspecialchars($precoInicial) ?>"
                   class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2"
                   placeholder="0,00">
        </div>

        <div>
            <label class="block text-sm mb-1 text-zinc-300">Imagem</label>
            <input id="imagemInput" type="file" name="imagem" accept=".jpg,.jpeg,.png,.webp"
                   class="w-full rounded-lg bg-blackx border border-blackx3 px-3 py-2">
            <img id="imgPreview"
                 src="<?= htmlspecialchars($imgAtual) ?>"
                 class="mt-2 h-24 w-24 object-cover rounded border border-blackx3 <?= $imgAtual ? '' : 'hidden' ?>">
        </div>

        <div class="pt-2">
            <button type="submit" class="rounded-lg bg-greenx text-black font-semibold px-5 py-2.5 hover:opacity-90">
                Salvar
            </button>
        </div>
    </form>
</div>

<script>
(function () {
    const display = document.getElementById('preco_display');
    const hidden = document.getElementById('preco');

    function onlyDigits(v) { return (v || '').replace(/\D/g, ''); }
    function formatBRLFromDigits(digits) {
        if (!digits) return '0,00';
        const num = Number(digits) / 100;
        return num.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function brlToFloat(brl) {
        const s = (brl || '').replace(/\./g, '').replace(',', '.').replace(/[^\d.]/g, '');
        const n = Number(s || 0);
        return n.toFixed(2);
    }

    if (display && hidden) {
        const init = onlyDigits(display.value);
        display.value = formatBRLFromDigits(init);
        hidden.value = brlToFloat(display.value);

        display.addEventListener('input', function () {
            const d = onlyDigits(display.value);
            display.value = formatBRLFromDigits(d);
            hidden.value = brlToFloat(display.value);
        });
    }

    const input = document.getElementById('imagemInput');
    const preview = document.getElementById('imgPreview');

    if (input && preview) {
        input.addEventListener('change', function () {
            const file = input.files && input.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function (e) {
                preview.src = String(e.target?.result || '');
                preview.classList.remove('hidden');
            };
            reader.readAsDataURL(file);
        });
    }
})();
</script>

